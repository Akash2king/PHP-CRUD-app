# Copy to .env and edit: cp .env.example .env

# App
PORT=80
WEB_BIND=0.0.0.0
HOST_HTTP_PORT=80
USE_EMBEDDED_DB=auto

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=crud
DB_USER=cruduser
DB_PASSWORD=crudpass
DB_ROOT_PASSWORD=rootpass
DB_SSL=false

# Optional path inside container (default loads /run/config/.env and /var/www/html/.env)
# ENV_FILE=/run/config/.env
