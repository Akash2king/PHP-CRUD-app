# Built into Dockerfile (override with docker run -e or Azure Container Apps env)

PORT=8080
WEB_BIND=0.0.0.0
USE_EMBEDDED_DB=auto

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=crud
DB_USER=cruduser
DB_PASSWORD=crudpass
DB_ROOT_PASSWORD=rootpass

# Local Docker on port 80:
#   docker run -p 80:80 -e PORT=80 -e WEB_BIND=0.0.0.0 php-crud-app
#
# Azure Container Apps: set USE_EMBEDDED_DB=false and point DB_HOST to Azure MySQL.
# Ingress targetPort must match PORT (default 8080).
